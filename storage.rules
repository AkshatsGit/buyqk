rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile pictures: authenticated users can read all, write only their own
    match /profile_pictures/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Resume documents: authenticated users can read all, write only their own
    match /resumes/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // Chat / shared media: authenticated users
    match /chat_media/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 20 * 1024 * 1024;
    }

    // Shop assets: authenticated
    match /shops/{shopId}/{filename} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Products: authenticated
    match /products/{productId}/{filename} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Fallback: deny everything else
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
