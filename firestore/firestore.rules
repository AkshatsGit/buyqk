rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------
    // PUBLIC READS — shops, products, inventory visible to all
    // -----------------------------------------------
    match /shops/{shopId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /inventory/{invId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /categories/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // -----------------------------------------------
    // USER PROFILES
    // -----------------------------------------------
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /sellers/{sellerId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /customers/{customerId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // -----------------------------------------------
    // ORDERS
    // -----------------------------------------------
    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /order_groups/{groupId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // -----------------------------------------------
    // GEOGRAPHY (admin manages, public reads)
    // -----------------------------------------------
    match /cities/{cityId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /areas/{areaId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /zones/{zoneId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // -----------------------------------------------
    // PLATFORM CONFIG
    // -----------------------------------------------
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // -----------------------------------------------
    // HR & TEAM PORTALS
    // -----------------------------------------------
    match /hr_offers/{offerId} {
      allow read, write: if request.auth != null;
    }

    match /team_members/{memberId} {
      allow read, write: if request.auth != null;
    }
  }
}
