{
  "name": "buyqk-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "buyQk Local Commerce Platform Monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:store": "node packages/store-server/index.js",
    "dev:customer": "npm run dev --workspace=apps/customer-web",
    "dev:seller": "npm run dev --workspace=apps/seller-web",
    "dev:admin": "npm run dev --workspace=apps/admin-web",
    "dev:hr": "npm run dev --workspace=apps/hr-web",
    "dev:team": "npm run dev --workspace=apps/team-web",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "tsc --noEmit --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
