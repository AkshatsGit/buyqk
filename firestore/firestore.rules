rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper: is the requesting user the super admin? ──────────────────────
    function isSuperAdmin() {
      return request.auth != null &&
             request.auth.token.email == 'akshat.srivastava098@gmail.com';
    }

    // ─── Helper: is the user a promoted admin? ────────────────────────────────
    function isAdmin() {
      return request.auth != null && (
        isSuperAdmin() ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
      );
    }

    // ─── Helper: is the request from any authenticated user? ─────────────────
    function isAuthed() {
      return request.auth != null;
    }

    // -----------------------------------------------
    // PUBLIC READS — shops, products, inventory visible to all
    // -----------------------------------------------
    match /shops/{shopId} {
      allow read: if true;
      allow write: if isAuthed();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAuthed();
    }

    match /inventory/{invId} {
      allow read: if true;
      allow write: if isAuthed();
    }

    match /categories/{id} {
      allow read: if true;
      allow write: if isAuthed();
    }

    // -----------------------------------------------
    // USER PROFILES
    // Any authenticated user can read all profiles (needed for directory, chat)
    // Any authenticated user can write their OWN profile
    // Super admin can write ANY user's profile (for approve/disable/promote)
    // -----------------------------------------------
    match /users/{userId} {
      allow read:   if isAuthed();
      allow create: if isAuthed() && request.auth.uid == userId;
      allow update: if isAuthed() && (
        request.auth.uid == userId || isSuperAdmin() || isAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    match /sellers/{sellerId} {
      allow read, write: if isAuthed();
    }

    match /customers/{customerId} {
      allow read, write: if isAuthed();
    }

    // -----------------------------------------------
    // ORDERS
    // -----------------------------------------------
    match /orders/{orderId} {
      allow read, write: if isAuthed();
    }

    match /order_groups/{groupId} {
      allow read, write: if isAuthed();
    }

    // -----------------------------------------------
    // GEOGRAPHY (admin manages, public reads)
    // -----------------------------------------------
    match /cities/{cityId} {
      allow read: if true;
      allow write: if isAuthed();
    }
    match /areas/{areaId} {
      allow read: if true;
      allow write: if isAuthed();
    }
    match /zones/{zoneId} {
      allow read: if true;
      allow write: if isAuthed();
    }

    // -----------------------------------------------
    // PLATFORM CONFIG
    // -----------------------------------------------
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAuthed();
    }

    // -----------------------------------------------
    // HR & TEAM PORTALS
    // -----------------------------------------------
    match /hr_offers/{offerId} {
      allow read, write: if isAuthed();
    }

    match /team_members/{memberId} {
      allow read, write: if isAuthed();
    }

    // -----------------------------------------------
    // TEAM-WEB: ANNOUNCEMENTS
    // Any authenticated user can read.
    // Only super admin or promoted admin can create/update/delete.
    // -----------------------------------------------
    match /announcements/{annId} {
      allow read:   if isAuthed();
      allow create: if isAdmin() || isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // -----------------------------------------------
    // TEAM-WEB: GROUP CHANNELS
    // Any authenticated user can read and create groups.
    // Only group creator, admin, or super admin can update/delete.
    // -----------------------------------------------
    match /groups/{groupId} {
      allow read:   if isAuthed();
      allow create: if isAuthed();
      allow update: if isAuthed() && (
        resource.data.createdBy == request.auth.uid || isSuperAdmin() || isAdmin()
      );
      allow delete: if isSuperAdmin() || isAdmin();
    }

    // -----------------------------------------------
    // TEAM-WEB: DIRECT CHAT METADATA
    // Both participants can read/write the chat document.
    // -----------------------------------------------
    match /directChats/{chatId} {
      allow read, write: if isAuthed();
    }

    // -----------------------------------------------
    // TEAM-WEB: CHAT MESSAGES (RTDB handles real messages,
    // but if any Firestore messages collection is used)
    // -----------------------------------------------
    match /messages/{chatId} {
      allow read, write: if isAuthed();
      match /msgs/{msgId} {
        allow read, write: if isAuthed();
      }
    }
  }
}
